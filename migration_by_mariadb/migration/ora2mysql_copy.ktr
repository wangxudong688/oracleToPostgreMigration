<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>ora2mysql_copy</name>
    <description>单表迁移：从 Oracle 读取数据，写入 MySQL</description>
    <extended_description>使用前需定义变量：TABLE_NAME, ORACLE_HOST, ORACLE_PORT, ORACLE_DATABASE, ORACLE_USER, ORACLE_PASS, MYSQL_HOST, MYSQL_PORT, MYSQL_DATABASE, MYSQL_USER, MYSQL_PASS, COMMIT_SIZE</extended_description>
    <trans_version>1.0</trans_version>
    <trans_type>Normal</trans_type>
    <directory>&#x2f;</directory>
    <parameters>
      <parameter>
        <name>TABLE_NAME</name>
        <default_value/>
        <description>要迁移的表名</description>
      </parameter>
      <parameter>
        <name>COMMIT_SIZE</name>
        <default_value>1000</default_value>
        <description>每批提交的行数</description>
      </parameter>
    </parameters>
    <log>
      <loglevel>Basic</loglevel>
    </log>
    <maxdate>
      <connection/>
      <table/>
      <field/>
      <offset>0</offset>
      <maxdiff>0</maxdiff>
    </maxdate>
    <size_rowset>10000</size_rowset>
    <sleep_interval>0</sleep_interval>
    <unique_connections>N</unique_connections>
    <pass_batchid>Y</pass_batchid>
    <shared_objects>
      <connections>
        <connection>
          <name>ORACLE</name>
          <server>${ORACLE_HOST}</server>
          <type>Oracle</type>
          <access>Native</access>
          <database>${ORACLE_DATABASE}</database>
          <port>${ORACLE_PORT}</port>
          <username>${ORACLE_USER}</username>
          <password>${ORACLE_PASS}</password>
          <servername/>
          <data_tablespace/>
          <index_tablespace/>
          <read_only>Y</read_only>
          <is_option>Y</is_option>
          <attributes>
            <attribute><code>STREAM_RESULTS</code><attribute>Y</attribute></attribute>
            <attribute><code>USE_BATCH_SIZE</code><attribute>Y</attribute></attribute>
            <attribute><code>BATCH_SIZE</code><attribute>50000</attribute></attribute>
          </attributes>
        </connection>
        <connection>
          <name>MYSQL</name>
          <server>${MYSQL_HOST}</server>
          <type>MySQL</type>
          <access>Native</access>
          <database>${MYSQL_DATABASE}</database>
          <port>${MYSQL_PORT}</port>
          <username>${MYSQL_USER}</username>
          <password>${MYSQL_PASS}</password>
          <servername/>
          <data_tablespace/>
          <index_tablespace/>
          <read_only>N</read_only>
          <is_option>Y</is_option>
          <attributes>
            <attribute><code>STREAM_RESULTS</code><attribute>Y</attribute></attribute>
            <attribute><code>USE_BATCH_SIZE</code><attribute>Y</attribute></attribute>
            <attribute><code>BATCH_SIZE</code><attribute>50000</attribute></attribute>
          </attributes>
        </connection>
      </connections>
    </shared_objects>
  </info>
  <order>
    <hop>
      <from>Oracle 表输入</from>
      <to>MySQL 表输出</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <step>
    <name>Oracle 表输入</name>
    <type>TableInput</type>
    <description>从 Oracle 读取数据</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partition>
      <partition_type>none</partition_type>
      <partition_size_per_row/>
      <partition_file_set_size/>
    </partition>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xLoc>160</xLoc>
      <yLoc>128</yLoc>
    </GUI>
    <file>
      <type>Fixed</type>
    </file>
    <connection>ORACLE</connection>
    <sql>SELECT * FROM ${TABLE_NAME}</sql>
    <limit>0</limit>
    <lookup>Y</lookup>
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <lazy_conversion_active>Y</lazy_conversion_active>
  </step>
  <step>
    <name>MySQL 表输出</name>
    <type>TableOutput</type>
    <description>写入 MySQL</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partition>
      <partition_type>none</partition_type>
      <partition_size_per_row/>
      <partition_file_set_size/>
    </partition>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xLoc>368</xLoc>
      <yLoc>128</yLoc>
    </GUI>
    <connection>MYSQL</connection>
    <schema/>
    <table>${TABLE_NAME}</table>
    <commit_size>${COMMIT_SIZE}</commit_size>
    <truncate>N</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partition_data_over_tables>N</partition_data_over_tables>
    <partitioning_field/>
    <partitioning_table_per_partition>N</partitioning_table_per_partition>
    <return_auto_generated_keys>N</return_auto_generated_keys>
    <auto_generated_key_field/>
  </step>
  <step_error_handling>
  </step_error_handling>
  <slave-step-copy-distribution>
  </slave-step-copy-distribution>
  <slave-server>
  </slave-server>
  <cluster_schema>
  </cluster_schema>
</transformation>
